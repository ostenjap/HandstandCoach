{
  "expo": {
    "name": "handstand-coach",
    "slug": "handstand-coach",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Handstand Coach needs the camera to analyze your handstand form in real time."
      }
    },
    "android": {
      "permissions": [
        "android.permission.CAMERA"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.handstandcoach"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "react-native-fast-tflite"
    ],
    "extra": {
      "eas": {
        "projectId": "372c24d1-7fcf-4c7a-9b69-763e84e8e399"
      }
    },
    "owner": "ostenjap"
  }
}
